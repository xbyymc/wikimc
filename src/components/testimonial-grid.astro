---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<div class="testimonial-wrapper not-content" data-pagefind-ignore>
	<div class="header">
		<h2 class="testimonial-grid-title">{title}</h2>
		<a 
			href="https://github.com/xbyymc/wikimc/blob/main/src/content/docs/index.mdx" 
			target="_blank" 
			rel="noopener noreferrer"
			class="add-testimonial-btn"
		>
			去留言
		</a>
	</div>
	<ul class="testimonial-grid">
		<slot />
	</ul>
</div>

<style>
	.testimonial-wrapper {
		margin-block: 7rem 2.5rem !important;
		font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
	}
	.header {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}
	.testimonial-grid-title {
		text-align: center;
		font-size: var(--sl-text-h3);
		font-weight: 600;
		color: var(--sl-color-white);
		line-height: var(--sl-line-height-headings);
	}
	.add-testimonial-btn {
		color: var(--sl-color-text-accent);
		font-size: var(--sl-text-sm);
		text-decoration: none;
		border: 1px solid var(--sl-color-text-accent);
		padding: 0.3em 0.8em;
		border-radius: 0.3rem;
		transition: all 0.2s ease;
	}
	.add-testimonial-btn:hover {
		background: var(--sl-color-text-accent);
		color: var(--sl-color-black);
	}
	.testimonial-grid {
		margin-top: 2.5rem;
		display: grid;
		gap: 3em;
		padding-inline-start: 0;
	}
	@media (min-width: 50rem) {
		.testimonial-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
